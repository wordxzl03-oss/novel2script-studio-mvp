# Copy this file to .env and fill in your own API key.
# Never commit the real .env file.

# ------------------------------------------------------------
# LLM runtime mode
# ------------------------------------------------------------
# live   = call a real OpenAI-compatible API
# record = call API and save request/response recordings
# replay = read local recordings without network request or API key
LLM_MODE=replay

# DEMO_MODE=1 forces replay mode for no-key demos.
DEMO_MODE=1

# ------------------------------------------------------------
# OpenAI-compatible LLM endpoint
# ------------------------------------------------------------
# Examples:
# OpenAI:   https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
# Qwen:     https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=

# ------------------------------------------------------------
# Replay / record files
# ------------------------------------------------------------
LLM_RECORDINGS_DIR=examples/llm_recordings

# ------------------------------------------------------------
# App settings
# ------------------------------------------------------------
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000