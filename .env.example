# LLM runtime mode:
# live   = call real LLM API
# record = call real LLM API and save request/response recordings
# replay = load saved recordings without API key
LLM_MODE=live

# Demo mode forces replay mode and does not require API key.
DEMO_MODE=0

# OpenAI-compatible API config.
# Server-side only: keep this key in the backend environment, never in frontend code.
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_API_KEY=your_api_key_here

# Replay / record fixtures
LLM_RECORDINGS_DIR=examples/llm_recordings

# App settings
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
RATE_LIMIT_PER_DAY=100
